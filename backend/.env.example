# Studioinfinito Backend - Environment Configuration
# Copy this file to .env and fill in the appropriate values for your environment

# ============================================
# Server Configuration
# ============================================
# Node environment (development|production|test)
# development: verbose logging, local defaults for CORS
# production: strict configuration, requires explicit CORS_ORIGINS
NODE_ENV=development

# API Server Port
PORT=26627

# ============================================
# Database Configuration
# ============================================
# MySQL/MariaDB database connection
DBHOST=localhost
DBNAME=task_manager
DBUSER=root
DBPASS=your_database_password
DBPORT=3306

# ============================================
# JWT Authentication
# ============================================
# Secret key for signing JWT tokens (minimum 32 characters recommended)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long
JWT_EXPIRES_IN=12h

# ============================================
# Email Configuration (SMTP)
# ============================================
# SMTP server for sending emails (password reset, notifications, etc.)
EMAILHOST=smtp.gmail.com
EMAILPORT=587
# Use TLS for secure connection (true for port 587, false for 25/unencrypted)
EMAILSECURE=false
# Email account credentials
EMAILUSER=your-email@gmail.com
# For Gmail: Use an App Password, not your account password
EMAILPASS=your-app-specific-password
# Sender email address (format: "Display Name <email@domain.com>")
EMAIL_FROM=Task Manager <no-reply@thestudioinfinito.com>

# ============================================
# Application URLs
# ============================================
# Backend API URL (used in emails, redirects, etc.)
# Development: http://localhost:26627
# Production: https://your-api-domain.com
BASE_URL_API=http://localhost:26627

# Frontend/Web App URL (used in emails, CORS, redirects)
# Development: http://localhost:3000
# Production: https://your-app-domain.com
BASE_URL_APP=http://localhost:3000

# ============================================
# CORS Configuration
# ============================================
# Allowed origins for cross-origin requests (comma-separated)
# 
# Development (automatically includes localhost:3000, localhost:3001):
# Leave blank or provide additional origins
# CORS_ORIGINS=http://localhost:5000,https://dev-app.example.com
#
# Production (must be explicitly set, no defaults):
# CORS_ORIGINS=https://app.thestudioinfinito.com,https://admin.thestudioinfinito.com
#
# Note: Production deployments should NOT include localhost origins
CORS_ORIGINS=

# ============================================
# Logging Configuration
# ============================================
# Log level (error|warn|info|debug|trace)
LOG_LEVEL=info

# ============================================
# Optional: Feature Flags & Advanced Configuration
# ============================================
# Add custom configuration variables here as needed for your deployment
