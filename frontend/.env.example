# ═══════════════════════════════════════════════════════════════════════
# TSI Task Manager — Frontend Environment Variables
# ═══════════════════════════════════════════════════════════════════════

# Application name (shown in browser title bar)
APP_NAME=TSI Task Manager

# ── API Configuration ───────────────────────────────────────────────────
# Local development (default)
API_BASE_URL=http://localhost:5000/api/v1

# Production (Render)
# API_BASE_URL=https://studioinfinito-api.onrender.com/api/v1

# ── Build Configuration ─────────────────────────────────────────────────
# BUILD_FLAVOR=development
# ENABLE_FIREBASE=false

# ── Password Reset ──────────────────────────────────────────────────────
# RESET_PASSWORD_ROUTE=https://task.thestudioinfinito.com/reset-password
